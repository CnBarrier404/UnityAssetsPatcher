<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
        <!-- 类型数据库必须与可执行文件一起发布，运行时从 AppContext.BaseDirectory 定位。 -->
        <Content Include="Assets\AssetsRipper.tpk">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="AssetsTools.NET" Version="3.0.4"/>
        <PackageReference Include="System.CommandLine" Version="2.0.8"/>
    </ItemGroup>

</Project>
