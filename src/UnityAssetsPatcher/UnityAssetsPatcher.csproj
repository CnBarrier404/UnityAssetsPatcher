<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    </PropertyGroup>

    <ItemGroup>
        <Content Include="Assets\AssetsRipper.tpk">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
            <TargetPath>resources.tpk</TargetPath>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\UnityAssetsPatcher.AssetsTools\UnityAssetsPatcher.AssetsTools.csproj"/>
        <ProjectReference Include="..\UnityAssetsPatcher.Tui\UnityAssetsPatcher.Tui.csproj"/>
    </ItemGroup>

</Project>
